# =============================================================================
# AI Copilot + Multi-Tenant Analytics Platform — .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Secrets & environment variables — NEVER commit these
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
secrets/
credentials/

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so

# Virtual environments
.venv/
venv/
env/
ENV/

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg
.eggs/

# Pytest / coverage
.pytest_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/

# MyPy / Pyright type checker caches
.mypy_cache/
.pyright/

# Jupyter notebooks checkpoints
.ipynb_checkpoints/

# -----------------------------------------------------------------------------
# Machine Learning artefacts
# -----------------------------------------------------------------------------
*.pkl
*.joblib
*.h5
*.onnx
models/
checkpoints/
runs/
mlruns/
wandb/

# -----------------------------------------------------------------------------
# Data files — business data should never be committed
# -----------------------------------------------------------------------------
data/
datasets/
uploads/
*.csv
*.tsv
*.parquet
*.feather
*.xlsx
*.xls
*.json.gz

# -----------------------------------------------------------------------------
# Logs & temporary files
# -----------------------------------------------------------------------------
logs/
*.log
*.tmp
*.bak
*.swp
*.swo

# -----------------------------------------------------------------------------
# Databases & local storage
# -----------------------------------------------------------------------------
*.db
*.sqlite
*.sqlite3
pgdata/

# -----------------------------------------------------------------------------
# Docker
# -----------------------------------------------------------------------------
docker-compose.override.yml
.docker/

# -----------------------------------------------------------------------------
# Node.js / frontend (for future dashboard service)
# -----------------------------------------------------------------------------
node_modules/
.next/
out/
.nuxt/
dist/
.cache/
*.tsbuildinfo

# -----------------------------------------------------------------------------
# OS-generated files
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# -----------------------------------------------------------------------------
# IDEs & editors
# -----------------------------------------------------------------------------
.vscode/settings.json
.idea/
*.iml
*.suo
*.user
