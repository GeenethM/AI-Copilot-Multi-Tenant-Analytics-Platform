# ─────────────────────────────────────────────────────────────────────────────
# Shared Database Layer — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# 1. Copy this file:   cp .env.example .env
# 2. Fill in your DATABASE_URL
# 3. Never commit your real .env file
# ─────────────────────────────────────────────────────────────────────────────

# Full async PostgreSQL connection string.
# Format: postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DATABASE
#
# Local PostgreSQL (default after `createdb analytics_platform`):
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/analytics_platform

# Set to true to print all SQL statements to stdout (dev/debug only)
DATABASE_ECHO=false
