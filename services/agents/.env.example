# ─────────────────────────────────────────────────────────────────────────────
# AI Agent Service — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# 1. Copy this file:   cp .env.example .env
# 2. Fill in the values below (only the keys for your chosen provider)
# 3. Never commit your real .env file — it's already in .gitignore
# ─────────────────────────────────────────────────────────────────────────────

# Which LLM provider to use: openai | anthropic | google
LLM_PROVIDER=openai

# API Keys — only the key for your chosen provider is required
OPENAI_API_KEY=your-openai-api-key-here
ANTHROPIC_API_KEY=your-anthropic-api-key-here
GOOGLE_API_KEY=your-google-api-key-here

# Model name — must match your chosen provider
# OpenAI:    gpt-4o | gpt-4o-mini | gpt-4-turbo
# Anthropic: claude-3-5-sonnet-20241022 | claude-3-haiku-20240307
# Google:    gemini-1.5-pro | gemini-1.5-flash
MODEL_NAME=gpt-4o

# 0.0 = fully deterministic (best for business agents)
# 1.0 = most creative / variable
TEMPERATURE=0.0
