# ─────────────────────────────────────────────────────────────────────────────
# Analytics Service — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# 1. Copy this file:   cp .env.example .env
# 2. Fill in values
# 3. Never commit your real .env file
# ─────────────────────────────────────────────────────────────────────────────

# Z-score threshold for anomaly detection.
# Values beyond this many standard deviations from the mean are flagged.
# 2.5 is a sensible default — lower = more sensitive, higher = fewer flags.
ANOMALY_Z_SCORE_THRESHOLD=2.5

# Number of periods used for rolling average calculation
ROLLING_WINDOW=3

# -- Database (shared multi-tenant PostgreSQL layer) -------------------------
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/analytics_platform

