# ─────────────────────────────────────────────────────────────────────────────
# Predictive ML Service — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# 1. Copy this file:   cp .env.example .env
# 2. Fill in values
# 3. Never commit your real .env file
# ─────────────────────────────────────────────────────────────────────────────

# Where trained models are stored on disk (relative to services/ml/)
MODELS_DIRECTORY=./saved_models

# Default model algorithm: random_forest | gradient_boosting | linear_regression
DEFAULT_MODEL_TYPE=random_forest

# Fraction of data used for evaluation (0.2 = 20% held back for testing)
TEST_SIZE=0.2

# Ensures reproducible results across runs
RANDOM_STATE=42

# Max rows used when computing SHAP explanations (lower = faster)
SHAP_BACKGROUND_SAMPLES=100

# -- Database (shared multi-tenant PostgreSQL layer) -------------------------
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/analytics_platform

